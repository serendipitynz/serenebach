// AI compose action catalogue.
//
// Each entry defines the system prompt, max output token cap, and
// sampling temperature for one /admin/ai/compose action. Edit this
// file to tune wording or limits; values are loaded once at startup.
//
// Placeholders in `system`:
//   {format} → "markdown" | "html"
//   {lang}   → "Japanese" | "English" (display name)
//
// Headroom note for `max_tokens`:
// caps account for reasoning/thinking models (qwen3, llm-jp-thinking,
// deepseek-r1, gemma thinking variants) that spend most of
// completion_tokens on hidden chain-of-thought before emitting the
// final answer. Non-thinking models stop on `stop` well before these
// limits, so widening the ceiling has no cost on them but lets
// thinking models actually reach the final answer. Title / tags /
// keywords look like they only need a few tokens of final output,
// but the reasoning budget they consume on the way there is
// comparable to longer tasks — keep the cap generous on purpose.
{
  // Rewrite — light polishing pass over user-provided text. Highest
  // cap because the output is roughly the same length as the input
  // and inputs can be sizeable selections.
  "rewrite": {
    "system": "You are a concise writing assistant. Rewrite the passage the user sends so it reads more naturally while preserving meaning, tone, and any {format} markup. Return only the rewritten passage — no preamble, no commentary, no quotation marks. Reply in {lang}.",
    "max_tokens": 4096,
    // 0.2 keeps the rewrite close to the source so meaning/voice
    // don't drift; hallucinations stay rare.
    "temperature": 0.2
  },

  // Continue — extend the draft with one or two additional paragraphs.
  "continue": {
    "system": "You are a concise writing assistant. Continue the passage the user sends with one or two additional paragraphs that match the existing voice and {format} markup. Return only the new text — do not repeat what was already written. Reply in {lang}.",
    "max_tokens": 2048,
    "temperature": 0.2
  },

  // Summarise — single short paragraph distillation.
  "summarise": {
    "system": "Summarise the passage in one short paragraph (under 120 words) in {lang}. No preamble.",
    "max_tokens": 2048,
    // Slightly higher than rewrite; paraphrasing benefits from a
    // bit of latitude without going off-topic.
    "temperature": 0.3
  },

  // Title — single line headline suggestion.
  "title": {
    "system": "Suggest a short, engaging title for the entry below. Reply with exactly one title, no quotation marks, no preamble, under 40 characters. Reply in {lang}.",
    "max_tokens": 2048,
    // 0.7 lets the model find a punchier framing rather than the
    // most literal restatement of the body.
    "temperature": 0.7
  },

  // Tags — comma-separated taxonomy suggestions.
  "tags": {
    "system": "Suggest 3-6 short tags (1-3 words each) for the entry below. Reply with a single line of comma-separated tags. No preamble, no numbering, no quotation marks. Tags should be in {lang}.",
    "max_tokens": 2048,
    "temperature": 0.7
  },

  // Keywords — comma-separated SEO keyword line.
  "keywords": {
    "system": "Suggest SEO keywords for the entry below. Reply with a single line of comma-separated keywords (5-10 total). No preamble. Keywords should be in {lang}.",
    "max_tokens": 2048,
    "temperature": 0.7
  }
}
