# Serene Bach — local environment template.
# Copy this file to `.env` and fill in real values. Taskfile.yml's
# dotenv directive loads `.env` automatically for every task, so
# `task dev` picks these up without any extra flags.
# `.env` is gitignored; `.env.example` is committed.

# Master key for AI writing-assist credentials. Any
# non-empty string works — the value is hashed with SHA-256 to
# derive the AES-256-GCM key. Changing this value invalidates every
# saved API key (users will need to re-enter theirs on
# /admin/profile), so pick once and keep it.
SB_AI_SECRET=change-me-to-a-long-random-string

# --- Optional knobs (uncomment + adjust as needed) ---

# Split the analytics pageview table into its own SQLite file. Leave
# unset to keep everything in the main DB.
# SB_ANALYTICS_DB=./data/analytics.db

# How many days of page-view rows to keep. 0 = forever.
# SB_ANALYTICS_RETENTION_DAYS=30

# Turn off pageview recording entirely.
# SB_ANALYTICS_DISABLED=1

# Split the MCP write-tool audit log into its own SQLite file.
# SB_MCP_AUDIT_DB=./data/mcp_audit.db

# Upload size cap (MB) for image uploads; default is 10.
# SB_UPLOAD_MAX_MB=10

# Image / template / static-rebuild directories. Defaults are
# under ./data/ so the CGI-style "drop the binary in" layout works.
# SB_IMAGE_DIR=./data/img
# SB_TEMPLATE_DIR=./data/templates
# SB_REBUILD_OUT=./data/public

# Cloudflare Turnstile (anti-spam challenge on the comment form).
# Leave both blank to disable.
# SB_TURNSTILE_SITEKEY=
# SB_TURNSTILE_SECRET=

# Trusted proxy CIDRs. When set, X-Forwarded-For / X-Real-IP are
# honoured only if the immediate peer (RemoteAddr) is on this list;
# otherwise the headers are ignored and RemoteAddr wins. Leave unset
# for direct-to-internet deployments — it's the safe default.
# Comma-separated, accepts CIDR or bare addresses (v4 / v6).
# SB_TRUSTED_PROXIES=127.0.0.1,10.0.0.0/8

# Extra origins permitted for reader-facing POSTs (comment / like /
# stamp). The runtime always allows the configured weblog BaseURL,
# so this is only needed if a different host is allowed to send POSTs
# to the dynamic backend (e.g. a reverse proxy that rewrites Origin).
# Comma-separated; each entry must be a full scheme://host[:port].
#
# Note: this only governs the *receive* side. Static rebuild output
# still uses the single weblog BaseURL for links + form action
# (action="/entry/X/comment" is relative). Full split-origin
# deployments — static on a CDN host, dynamic backend on a different
# host — are not yet supported end-to-end; they need an additional
# DynamicBaseURL knob to rewrite form actions to absolute URLs. See
# the project design memo for the eventual shape.
# SB_PUBLIC_ALLOWED_ORIGINS=https://static.example.net,https://blog.example.com
